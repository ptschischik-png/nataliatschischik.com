{% set hasContactSection = hasInlineContactSection or isHome %}
{% set contactHref = '#contact' if hasContactSection else '/#contact' %}
<footer class="footer" role="contentinfo">
  <div class="footer-inner">
    <div>
      <div class="footer-brand">{{ site.contact.businessName }}</div>
      <div class="footer-tagline">Hochzeitsfotograf Kassel &middot; G&ouml;ttingen &middot; Marburg &middot; Gie&szlig;en &middot; Fulda &middot; Paderborn</div>
      <address class="footer-nap" style="font-style:normal;margin-top:1rem;font-size:0.75rem;line-height:1.8;color:rgba(196,181,171,0.7);">
        {{ site.contact.businessName }}<br>
        {{ site.contact.addressLines[0] }}<br>
        <a href="{{ site.contact.phoneHref }}" style="color:inherit;">{{ site.contact.phoneDisplay }}</a><br>
        <a href="{{ site.contact.emailHref }}" style="color:inherit;">{{ site.contact.email }}</a><br>
        <a href="{{ site.contact.mapsUrl }}" target="_blank" rel="noopener" style="color:rgba(196,181,171,0.5);text-decoration:underline;text-underline-offset:3px;">Auf Google Maps ansehen</a>
      </address>
    </div>
    <div class="footer-links">
      <div class="footer-col">
        <h4>Navigation</h4>
        <a href="/standorte">Standorte</a>
        <a href="/portfolio">Portfolio</a>
        <a href="/ueber-mich">Über mich</a>
        <a href="/preise">Preise</a>
        <a href="/faq">FAQ</a>
        <a href="/journal">Journal</a>
        <a href="{{ contactHref }}">Kontakt</a>
      </div>
      <div class="footer-col">
        <h4>Social</h4>
        <a href="https://www.instagram.com/hochzeitsfotografin.natalia/" target="_blank" rel="noopener noreferrer">Instagram</a>
      </div>
      <div class="footer-col">
        <h4>Rechtliches</h4>
        <a href="/impressum">Impressum</a>
        <a href="/datenschutz">Datenschutz</a>
      </div>
    </div>
  </div>
  <div class="footer-bottom">
    <span class="footer-copy">&copy; 2026 Natalia Tschischik — Hochzeitsfotograf Kassel</span>
  </div>
</footer>
