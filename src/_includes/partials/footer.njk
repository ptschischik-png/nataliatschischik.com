{% set hasContactSection = hasInlineContactSection or isHome %}
{% set contactHref = '#contact' if hasContactSection else '/#contact' %}
<footer class="footer" role="contentinfo">
  <div class="footer-inner">
    <div>
      <div class="footer-brand">{{ site.contact.businessName }}</div>
      <div class="footer-tagline">Hochzeitsfotograf Kassel<br>Baunatal &middot; G&ouml;ttingen &middot; Marburg &middot; Gie&szlig;en &middot; Fulda &middot; Frankenberg &middot; Schwalmstadt &middot; Kirchheim &middot; Paderborn &middot; Hildesheim &middot; Northeim &middot; Warburg &middot; Bad Hersfeld &middot; Bad Arolsen &middot; Borken &middot; Hofgeismar &middot; Nordhessen &middot; Hessen, NRW &amp; Niedersachsen</div>
      <address class="footer-nap" style="font-style:normal;margin-top:1rem;font-size:0.75rem;line-height:1.8;color:rgba(196,181,171,0.7);">
        {{ site.contact.businessName }}<br>
        {{ site.contact.addressLines[0] }}<br>
        <a href="{{ site.contact.phoneHref }}" style="color:inherit;">{{ site.contact.phoneDisplay }}</a><br>
        <a href="{{ site.contact.emailHref }}" style="color:inherit;">{{ site.contact.email }}</a><br>
        <a href="{{ site.contact.mapsUrl }}" target="_blank" rel="noopener" style="color:rgba(196,181,171,0.5);text-decoration:underline;text-underline-offset:3px;">Auf Google Maps ansehen</a>
      </address>
    </div>
    <div class="footer-links">
