<style>
.breadcrumbs {
  padding-top: 4.5rem;
  background: var(--cream, #F5F0E8);
  border-bottom: 1px solid rgba(44, 24, 16, 0.06);
}
.breadcrumbs-list {
  display: flex;
  flex-wrap: wrap;
  gap: 0;
  align-items: center;
  font-size: var(--text-xs, 0.75rem);
  font-weight: 400;
  letter-spacing: 0.06em;
  color: var(--brown-400, #9E8A80);
  line-height: 1.4;
  padding: 1rem 1.5rem;
}
.breadcrumbs-list li {
  display: inline-flex;
  align-items: center;
}
.breadcrumbs-list a {
  color: var(--brown-500, #7A6258);
  text-decoration: none;
  transition: color var(--transition, 0.3s ease);
}
.breadcrumbs-list a:hover {
  color: var(--accent, #5A2628);
}
.breadcrumbs-sep {
  color: var(--brown-300, #C4B5AB);
  margin: 0 0.5rem;
}
.breadcrumbs-current {
  color: var(--brown-500, #7A6258);
}
@media (max-width: 768px) {
  .breadcrumbs {
    padding-top: 4.35rem;
  }
  .breadcrumbs-list {
    padding: 0.95rem 1.25rem;
  }
  .breadcrumbs-sep {
    margin: 0 0.4rem;
  }
}
@media (min-width: 768px) {
  .breadcrumbs-list {
    padding-left: 3rem;
    padding-right: 3rem;
  }
}
</style>

<nav class="breadcrumbs" aria-label="Breadcrumb">
  <ol class="breadcrumbs-list">
    {% for crumb in breadcrumbItems %}
      <li>
        {% if crumb.url and not loop.last %}
          <a href="{{ crumb.url }}">{{ crumb.name }}</a>
        {% else %}
          <span class="breadcrumbs-current">{{ crumb.name }}</span>
        {% endif %}
        {% if not loop.last %}
          <span class="breadcrumbs-sep" aria-hidden="true">/</span>
        {% endif %}
      </li>
    {% endfor %}
  </ol>
</nav>
